# ── Firebase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=science-based-health
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── AI / Claude (required for AI food recognition & glucose features) ─────────
ANTHROPIC_API_KEY=

# ── Stripe (required for billing) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=

# ── Firebase Admin (required for Stripe webhook + FCM notifications) ──────────
# Base64-encode your service account JSON: base64 < service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── FCM Push Notifications (optional — enables web push) ──────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FCM_VAPID_KEY=

# ── Typesense Food Search (optional — falls back to local DB when not set) ────
# Provision at https://cloud.typesense.org (~$20/mo)
# Use a search-only API key (not admin key)
TYPESENSE_URL=
TYPESENSE_API_KEY=

# ── Dexcom CGM Integration (optional — enables real-time glucose sync) ────────
# Register at https://developer.dexcom.com → Create App → OAuth 2.0 credentials
# Set DEXCOM_REDIRECT_URI to: https://your-domain/api/integrations/dexcom/callback
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_REDIRECT_URI=http://localhost:3000/api/integrations/dexcom/callback
# Set to 'true' to use Dexcom sandbox (test data, no real device needed)
DEXCOM_SANDBOX=true

# ── Sentry Error Monitoring (optional) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── App URL (used in email templates) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
